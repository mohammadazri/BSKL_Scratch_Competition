# ──────────────────────────────────────────────────────────────────────────────
#  P3 Judging — Environment variables
# ──────────────────────────────────────────────────────────────────────────────
#
#  HOW TO USE
#  ----------
#  1. Copy this file:   cp .env.example .env
#  2. Fill in real values below (instructions per section).
#  3. NEVER commit .env (it's gitignored).
#
#  WHERE TO GET VALUES
#  -------------------
#  Sign up / log in at https://supabase.com → create a new project:
#    - Name:        p3-judging-2026
#    - Region:      Southeast Asia (Singapore)   ← closest to KL, lowest latency
#    - Plan:        Free
#    - Database PW: generate a long random one, save it in your password manager
#
#  Then go to:  Dashboard → your project → Settings → API
#  You'll find every key below on that page.
#
# ──────────────────────────────────────────────────────────────────────────────


# ─── SUPABASE (CLIENT-SIDE — exposed to the browser) ──────────────────────────
# These are SAFE to ship to the browser. They're guarded by Row Level Security.
# Settings → API → "Project URL" and "anon public" key.

PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...REPLACE_ME


# ─── SUPABASE (SERVER-SIDE — NEVER exposed to the browser) ────────────────────
# The service-role key bypasses Row Level Security and has full DB access.
# Treat it like a root password. Server-only — accessed via $env/static/private.
# Settings → API → "service_role secret" key.
# (The URL is the same value as PUBLIC_SUPABASE_URL — duplicated here so the
#  server-side imports don't reach into PUBLIC_*.)

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME


# ─── POSTGRES DIRECT CONNECTION (for Drizzle migrations + seed script) ────────
# Used by `pnpm drizzle-kit ...` and `pnpm tsx scripts/seed-rubrics.ts`.
# Settings → Database → Connection string → "URI" tab → Mode: "Session"
# Replace [YOUR-PASSWORD] with the DB password you set when creating the project.
#
# Example shape:
#   postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres


# ─── PUBLIC APP URL ───────────────────────────────────────────────────────────
# The canonical public URL of the deployed app — used to build email redirect
# URLs (magic link, password reset). If unset, the server falls back to the
# request origin, which means dev/Tailscale users would receive emails pointing
# at THEIR address (localhost:5173, 100.x.y.z:5173) instead of the public site.
# ALWAYS set this in production. Match it to Supabase Dashboard → Authentication
# → URL Configuration → Site URL.

PUBLIC_APP_URL=https://p3.sentrizk.me


# ─── SVELTEKIT NODE SERVER ────────────────────────────────────────────────────
# Used by the production Node adapter on the Raspberry Pi (Track 7).
# Local dev (`pnpm dev`) ignores these — Vite picks its own port.

HOST=127.0.0.1
PORT=3000
NODE_ENV=development


# ─── CLOUDFLARE ACCESS (OPTIONAL — only if you turn on Zero Trust app auth) ───
# Adds an extra email-allowlist gate IN FRONT OF Supabase Auth.
# Leave blank to disable. Fill in if you set up an Access application in the
# Cloudflare Zero Trust dashboard (Applications → Add).
# Found at: Zero Trust → Settings → General → "Team name" and the Access app's
# "Application Audience (AUD) Tag".

CF_ACCESS_AUD=
CF_ACCESS_TEAM_DOMAIN=


# ─── BACKUP DESTINATION (OPTIONAL — set on the Pi only, used by backup script) ─
# Where pg_dump writes snapshots during event day. A USB stick mounted on the Pi
# is the recommended target. Track 7 documents the cron setup.

BACKUP_DIR=/media/usb/p3-backups


# ─── AUDIT LOG STORAGE (OPTIONAL — Pi only) ───────────────────────────────────
# Path to the JSONL file the app appends audit events to. Defaults to
# `~/.p3-judging/audit.jsonl` if unset (the user home dir is safe across
# git pulls and pnpm install). Override if you want the log on the USB drive
# alongside backups.

AUDIT_LOG_PATH=


# ─── SUPER ADMIN BOOTSTRAP ────────────────────────────────────────────────────
# Used ONLY by `pnpm tsx scripts/seed-superadmin.ts` to create the first admin
# account. After the account exists, these values are never read by the app.

SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=ChooseAStrongOne
SUPER_ADMIN_NAME=Your Name
